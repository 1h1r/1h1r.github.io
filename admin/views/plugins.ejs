<!-- 插件管理 -->
<div class="page-title-bar">
  <h2><i class="fas fa-puzzle-piece"></i> 插件管理</h2>
  <span class="info-badge">
    已启用 <%= plugins.filter(p => p.enabled).length %> / <%= plugins.length %> 个插件
  </span>
</div>

<div class="plugins-grid">
  <% plugins.forEach(plugin => { %>
    <div class="plugin-card <%= plugin.enabled ? 'enabled' : 'disabled' %>">
      <div class="plugin-header">
        <div class="plugin-icon">
          <i class="fas <%= plugin.icon %>"></i>
        </div>
        <div class="plugin-info">
          <h4><%= plugin.name %></h4>
          <div class="plugin-meta">
            <span class="version">v<%= plugin.version %></span>
            <span class="author"><%= plugin.author %></span>
          </div>
        </div>
        <label class="switch">
          <input type="checkbox" <%= plugin.enabled ? 'checked' : '' %> 
                 onchange="togglePlugin('<%= plugin.id %>', this.checked)">
          <span class="slider"></span>
        </label>
      </div>
      <p class="plugin-desc"><%= plugin.description %></p>
      <div class="plugin-settings-list">
        <% for (const [key, val] of Object.entries(plugin.settings)) { %>
          <div class="setting-item">
            <span class="setting-name"><%= key %></span>
            <span class="setting-value"><%= typeof val === 'boolean' ? (val ? '✅' : '❌') : val %></span>
          </div>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>
