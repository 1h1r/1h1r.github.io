<!-- 分类标签管理 -->
<div class="page-title-bar">
  <h2><i class="fas fa-folder"></i> 分类与标签</h2>
</div>

<div class="categories-layout">
  <!-- 分类列表 -->
  <div class="content-card">
    <div class="card-header">
      <h3><i class="fas fa-folder"></i> 分类列表</h3>
      <span class="count-badge"><%= categories.length %> 个分类</span>
    </div>
    <div class="card-body">
      <% if (categories.length === 0) { %>
        <div class="no-data"><p>暂无分类</p></div>
      <% } else { %>
        <div class="category-list">
          <% categories.forEach(cat => { %>
            <div class="category-item">
              <div class="category-icon">
                <i class="fas fa-folder"></i>
              </div>
              <div class="category-content">
                <div class="category-name"><%= cat.name %></div>
                <div class="category-count"><%= cat.count %> 篇文章</div>
              </div>
              <div class="category-bar">
                <div class="bar-fill" style="width: <%= Math.min(100, cat.count * 10) %>%"></div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- 标签云 -->
  <div class="content-card">
    <div class="card-header">
      <h3><i class="fas fa-tags"></i> 标签云</h3>
      <span class="count-badge"><%= tags.length %> 个标签</span>
    </div>
    <div class="card-body">
      <% if (tags.length === 0) { %>
        <div class="no-data"><p>暂无标签</p></div>
      <% } else { %>
        <div class="tag-cloud">
          <% tags.forEach(tag => { %>
            <span class="tag-cloud-item" style="font-size: <%= 12 + Math.min(20, tag.count * 3) %>px">
              <%= tag.name %>
              <sup><%= tag.count %></sup>
            </span>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>
